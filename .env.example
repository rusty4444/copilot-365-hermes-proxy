# Microsoft 365 Copilot — Graph API credentials
# ---------------------------------------------------
# 1. Create an Azure AD app registration (confidential client)
# 2. Under Authentication:
#      - Add platform: "Mobile and desktop applications" or "Web"
#      - Turn OFF "Allow public client flows"
#      - (If available) ENABLE "Treat application as a confidential client"
# 3. Under API permissions → Microsoft Graph → Delegated permissions, add:
#      Sites.Read.All, Mail.Read, People.Read.All, OnlineMeetingTranscript.Read.All,
#      Chat.Read, ChannelMessage.Read.All, ExternalItem.Read.All
#    There is NO "Copilot.Chat" permission — the API checks for these 7 scopes.
# 4. Grant admin consent for all permissions
# 5. Under Certificates & secrets → create a client secret → copy the VALUE
# 6. Fill in the values below

AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret-value

# Graph API version (beta for Copilot Chat; v1.0 not supported)
GRAPH_API_VERSION=beta
COPILOT_MAX_TURNS=50

# Optional: user timezone for Copilot (default UTC)
USER_TIMEZONE=UTC

# Proxy bind address
COPILOT_PROXY_HOST=127.0.0.1
COPILOT_PROXY_PORT=8081
